#!/usr/bin/env bash
# agent-ping-hook — Claude Code hook wrapper for agent-ping notifications.
#
# Reads hook JSON from stdin, extracts session_id, and sends a state
# event to the AgentNotify Router. Tracks last-sent state per session
# to avoid duplicate notifications (e.g., back-to-back "start" events).
#
# Usage (in Claude Code hooks config):
#   agent-ping-hook <state>
#
# Where <state> is one of: start, waiting, completed, error
#
# Required environment variables:
#   AGENT_PING_WEBHOOK_URL  — The Apps Script web app URL
#
# Optional environment variables:
#   AGENT_PING_SECRET       — Shared secret sent as auth_token in JSON body
#   AGENT_PING_PROJECT      — Project name (default: basename of cwd)
#   AGENT_PING_SOURCE       — Source identifier (default: claude-code)
#   AGENT_PING_HOSTNAME     — Hostname override (default: system short hostname)
#   AGENT_PING_OS           — OS label override (default: uname -s)
#   AGENT_PING_INCLUDE_PROMPT — Set to 1/true/yes to include prompt previews

set -euo pipefail

STATE="${1:-}"
if [[ -z "$STATE" ]]; then
  echo "Usage: agent-ping-hook <start|waiting|completed|error>" >&2
  exit 1
fi

# Early exit if not configured — before reading stdin or requiring jq.
# This ensures teammates without the webhook (or without jq) get a silent no-op.
WEBHOOK_URL="${AGENT_PING_WEBHOOK_URL:-}"
if [[ -z "$WEBHOOK_URL" ]]; then
  cat > /dev/null  # drain stdin to avoid broken-pipe errors
  exit 0
fi

# Read hook JSON from stdin (requires jq).
INPUT=$(cat)

SESSION_ID=$(echo "$INPUT" | jq -r '.session_id // empty')
CWD=$(echo "$INPUT" | jq -r '.cwd // empty')

if [[ -z "$SESSION_ID" ]]; then
  echo "error: no session_id in hook input" >&2
  exit 1
fi

# Derive project name from cwd if not set.
PROJECT="${AGENT_PING_PROJECT:-$(basename "${CWD:-$(pwd)}")}"
SOURCE="${AGENT_PING_SOURCE:-claude-code}"
HOSTNAME_VALUE="${AGENT_PING_HOSTNAME:-$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo unknown-host)}"
OS_VALUE="${AGENT_PING_OS:-$(uname -s 2>/dev/null || echo unknown-os)}"
SESSION_SHORT_ID="${SESSION_ID:0:8}"
DETAILS=""

INCLUDE_PROMPT="${AGENT_PING_INCLUDE_PROMPT:-}"
if [[ "$INCLUDE_PROMPT" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  PROMPT=$(echo "$INPUT" | jq -r '
    first([
      .prompt?,
      .user_prompt?,
      .message?,
      .tool_input?.prompt?,
      .input?.prompt?,
      .hook_input?.prompt?
    ][] | select(type == "string" and length > 0)) // empty
  ')
  if [[ -n "$PROMPT" ]]; then
    DETAILS="Last prompt: $PROMPT"
  fi
fi

# --- Dedup: skip if last state for this session matches ---
STATE_DIR="${TMPDIR:-/tmp}/agent-ping-state"
mkdir -p "$STATE_DIR"
STATE_FILE="$STATE_DIR/$SESSION_ID"

if [[ -f "$STATE_FILE" ]]; then
  LAST_STATE=$(cat "$STATE_FILE")
  if [[ "$LAST_STATE" == "$STATE" ]]; then
    # Same state already sent — skip.
    exit 0
  fi
fi

# --- Build title based on state ---
case "$STATE" in
  start)     TITLE="Agent working" ;;
  waiting)   TITLE="Waiting for input" ;;
  completed) TITLE="Session completed" ;;
  error)     TITLE="Session error" ;;
  *)         TITLE="State: $STATE" ;;
esac

# --- Send the event ---
TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)

JQ_ARGS=(
  --arg task_id "$SESSION_ID"
  --arg project "$PROJECT"
  --arg state "$STATE"
  --arg source "$SOURCE"
  --arg title "$TITLE"
  --arg hostname "$HOSTNAME_VALUE"
  --arg os "$OS_VALUE"
  --arg cwd "${CWD:-$(pwd)}"
  --arg session_short_id "$SESSION_SHORT_ID"
  --arg timestamp "$TIMESTAMP"
)
JQ_EXPR='{
  task_id: $task_id,
  project: $project,
  state: $state,
  source: $source,
  title: $title,
  hostname: $hostname,
  os: $os,
  cwd: $cwd,
  session_short_id: $session_short_id,
  timestamp: $timestamp
}'

if [[ -n "$DETAILS" ]]; then
  JQ_ARGS+=(--arg details "$DETAILS")
  JQ_EXPR='{
    task_id: $task_id,
    project: $project,
    state: $state,
    source: $source,
    title: $title,
    hostname: $hostname,
    os: $os,
    cwd: $cwd,
    session_short_id: $session_short_id,
    timestamp: $timestamp,
    details: $details
  }'
fi

if [[ -n "${AGENT_PING_SECRET:-}" ]]; then
  JQ_ARGS+=(--arg auth_token "$AGENT_PING_SECRET")
  JQ_EXPR="$JQ_EXPR | .auth_token = \$auth_token"
fi

PAYLOAD=$(jq -n "${JQ_ARGS[@]}" "$JQ_EXPR")

CURL_ARGS=(-s -L -o /dev/null -w "%{http_code}" -H "Content-Type: application/json" -d "$PAYLOAD")

# Send synchronously so we can verify success before recording state.
# Use a short timeout to avoid blocking Claude Code for too long.
HTTP_CODE=$(curl --max-time 10 "${CURL_ARGS[@]}" "$WEBHOOK_URL" 2>/dev/null) || HTTP_CODE="000"

# Record state only on success — allows retry on next identical event if this one failed.
if [[ "$HTTP_CODE" == "200" ]]; then
  echo "$STATE" > "$STATE_FILE"
fi

exit 0
